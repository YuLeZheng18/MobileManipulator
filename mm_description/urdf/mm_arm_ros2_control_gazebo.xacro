<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <!-- Gazebo 版 ros2_control: 6 个机械臂关节由 gazebo_ros2_control 接管 -->
    <xacro:macro name="mm_arm_ros2_control_gazebo">
        <ros2_control name="GazeboSystem" type="system">
            <hardware>
                <plugin>gazebo_ros2_control/GazeboSystem</plugin>
            </hardware>
            <xacro:macro name="arm_joint" params="jname init">
                <joint name="${jname}">
                    <command_interface name="position"/>
                    <state_interface name="position">
                        <param name="initial_value">${init}</param>
                    </state_interface>
                    <state_interface name="velocity"/>
                    <state_interface name="effort"/>
                </joint>
            </xacro:macro>
            <xacro:arm_joint jname="Joint_11" init="0"/>
            <xacro:arm_joint jname="Joint_12" init="0"/>
            <xacro:arm_joint jname="Joint_13" init="0"/>
            <xacro:arm_joint jname="Joint_14" init="0"/>
            <xacro:arm_joint jname="Joint_15" init="0"/>
            <xacro:arm_joint jname="Joint_16" init="0"/>
        </ros2_control>

        <!-- gazebo_ros2_control 插件: 加载 controller_manager 和 controllers -->
        <gazebo>
            <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
                <parameters>$(find arm_moveit_config)/config/ros2_controllers.yaml</parameters>
            </plugin>
        </gazebo>
    </xacro:macro>
</robot>
