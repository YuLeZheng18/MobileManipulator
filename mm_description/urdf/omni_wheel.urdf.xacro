<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="omni_wheel" params="wheel_name parent xyz yaw_sign">
    <link name="${wheel_name}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="1.57079632679 0 ${yaw_sign * 0.78539816339}"/>
        <geometry>
          <cylinder radius="0.0635" length="0.05"/>
        </geometry>
        <material name="black">
          <color rgba="0.05 0.05 0.05 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="1.57079632679 0 ${yaw_sign * 0.78539816339}"/>
        <geometry>
          <cylinder radius="0.0635" length="0.05"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.4"/>
        <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
      </inertial>
    </link>

    <joint name="${wheel_name}_wheel_joint" type="continuous">
      <origin xyz="${xyz}" rpy="1.57079632679 0 ${yaw_sign * 0.78539816339}"/>
      <parent link="${parent}"/>
      <child link="${wheel_name}_wheel_link"/>
      <axis xyz="0 0 1"/>
    </joint>

    <gazebo reference="${wheel_name}_wheel_link">
      <material>Gazebo/DarkGrey</material>
      <mu1 value="1.0"/>
      <mu2 value="1.0"/>
      <kp value="1000000.0"/>
      <kd value="10.0"/>
    </gazebo>
  </xacro:macro>
</robot>
