<?xml version="1.0"?>
<robot name="mm_omni_base" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- 材料定义 -->
  <material name="yellow">
    <color rgba="1 1 0 1"/> 
  </material>
  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>
  <material name="red">
    <color rgba="0.9 0.1 0.1 1.0"/>
  </material>

  <!-- 底盘参数 - 整车投影约 400mm x 400mm -->
  <xacro:property name="body_length" value="0.30"/>
  <xacro:property name="body_width" value="0.30"/>
  <xacro:property name="body_height" value="0.03"/>
  
  <!-- 轮子参数 -->
  <xacro:property name="wheel_radius" value="0.05"/>
  <xacro:property name="wheel_length" value="0.05"/>
  <xacro:property name="wheel_offset_x" value="0.15"/>
  <xacro:property name="wheel_offset_y" value="0.15"/>

  <!-- base_link作为根链接 -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${body_length} ${body_width} ${body_height}"/>
      </geometry>
      <material name="yellow"/>
    </visual>
    <collision>
      <geometry>
        <box size="${body_length} ${body_width} ${body_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.08" iyy="0.08" izz="0.08" ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
  </link>
  
  <!-- base_footprint用于TF发布 -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- 激光雷达链接 -->
  <link name="laser_link">
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.04"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.04" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0002" iyy="0.0002" izz="0.0002" ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
  </link>

  <!-- 雷达安装在底盘上方 -->
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_link"/>
    <origin xyz="0.0 0.0 0.08" rpy="0 0 0"/>
  </joint>

  <!-- 四个全向轮 -->
  <!-- 轮子1: 前右 -->
  <link name="wheel_link1">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
  </link>

  <joint name="joint_wheel1" type="continuous">
    <origin xyz="${wheel_offset_x} ${wheel_offset_y} 0" rpy="1.5708 0 -0.7854"/>
    <parent link="base_link"/>
    <child link="wheel_link1"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- 轮子2: 前左 -->
  <link name="wheel_link2">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
  </link>

  <joint name="joint_wheel2" type="continuous">
    <origin xyz="${wheel_offset_x} -${wheel_offset_y} 0" rpy="1.5708 0 0.7854"/>
    <parent link="base_link"/>
    <child link="wheel_link2"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- 轮子3: 后左 -->
  <link name="wheel_link3">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
  </link>

  <joint name="joint_wheel3" type="continuous">
    <origin xyz="-${wheel_offset_x} -${wheel_offset_y} 0" rpy="1.5708 0 -0.7854"/>
    <parent link="base_link"/>
    <child link="wheel_link3"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- 轮子4: 后右 -->
  <link name="wheel_link4">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
  </link>

  <joint name="joint_wheel4" type="continuous">
    <origin xyz="-${wheel_offset_x} ${wheel_offset_y} 0" rpy="1.5708 0 0.7854"/>
    <parent link="base_link"/>
    <child link="wheel_link4"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Gazebo材质设置 -->
  <gazebo reference="base_link">
    <material>Gazebo/Yellow</material>
  </gazebo>
  <gazebo reference="wheel_link1">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="wheel_link2">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="wheel_link3">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="wheel_link4">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="laser_link">
    <material>Gazebo/Red</material>
  </gazebo>

  <!-- 激光雷达传感器 -->
  <gazebo reference="laser_link">
    <sensor name="lidar_sensor" type="ray">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>1200</samples>
            <resolution>1</resolution>
            <min_angle>-2.61799</min_angle>
            <max_angle>2.61799</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>25.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin name="laser_plugin" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>laser_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- planar_move控制器 -->
  <gazebo>
    <plugin name="object_controller" filename="libgazebo_ros_planar_move.so">
      <commandTopic>cmd_vel</commandTopic>
      <odometryTopic>odom</odometryTopic>
      <odometryFrame>odom</odometryFrame>
      <odometryRate>50.0</odometryRate>
      <robotBaseFrame>base_footprint</robotBaseFrame>
      <publishTF>true</publishTF>
    </plugin>
  </gazebo>
</robot>
